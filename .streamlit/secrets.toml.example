# ============================================================
# Streamlit Community Cloud 용 시크릿 양식
# ============================================================
# 사용법
#  - 로컬: 이 파일을 같은 폴더에 `secrets.toml` 로 복사한 뒤 값을 채웁니다.
#  - Cloud: 앱 대시보드 → ⋮ → Settings → Secrets 에 아래 내용을
#           그대로 붙여넣고 값만 교체합니다.
#
# ⚠️ 실제 키가 들어 있는 secrets.toml 은 절대 커밋하지 마세요
#    (.gitignore 에 이미 등록되어 있습니다).
# ============================================================


# --- KIS OpenAPI 자격증명 (필수) -----------------------------
# 발급 위치: https://apiportal.koreainvestment.com
#   1) 로그인 → 마이페이지 → 앱 관리 → 앱 등록
#   2) 발급받은 "APP KEY" / "APP SECRET" 값을 그대로 붙여넣기
#   3) "사용 IP 등록" 에 Streamlit Cloud 서버 IP 도 추가
#      (배포 후 호출 실패 시 에러 메시지에 표시되는 IP)
KIS_APP_KEY    = "여기에_APP_KEY_붙여넣기"
KIS_APP_SECRET = "여기에_APP_SECRET_붙여넣기"


# --- 환경 선택 (선택, 기본값 "real") -------------------------
# real : 실거래 서버 (https://openapi.koreainvestment.com:9443)
# mock : 모의투자 서버 (https://openapivts.koreainvestment.com:29443)
#   → 모의투자 키와 실서버 키는 서로 다릅니다.
KIS_ENV = "real"
