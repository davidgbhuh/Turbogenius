# ============================================================
# 로컬 실행용 환경변수 양식
# ============================================================
# 사용법: 이 파일을 `.env` 로 복사 후 값을 채워주세요.
# (.env 는 .gitignore 에 등록되어 커밋되지 않습니다)
#
# Streamlit Community Cloud 에 배포할 때는 이 파일 대신
# .streamlit/secrets.toml.example 양식을 사용하세요.
# ============================================================

# --- KIS OpenAPI 자격증명 (필수) ---
# 발급: https://apiportal.koreainvestment.com  → 마이페이지 → 앱 관리
KIS_APP_KEY=
KIS_APP_SECRET=

# --- 환경 선택 (선택) ---
# real : 실거래 서버 (기본값)
# mock : 모의투자 서버
KIS_ENV=real
